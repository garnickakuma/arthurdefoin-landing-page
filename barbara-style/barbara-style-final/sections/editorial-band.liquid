<section class="editorial-band vx-grain vx-veil" aria-label="Citation">
  <div class="editorial-band__bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | img_url: '2000x840', crop: 'center' }}"
        alt="{{ section.settings.image.alt | default: 'Barbara Style' | escape }}"
        width="2000" height="840"
        loading="lazy"
      >
    {%- endif -%}
  </div>

  <div class="editorial-band__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="vx-eyebrow" style="color:rgba(255,255,255,.75);margin-bottom:18px;">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <blockquote class="editorial-band__quote">
      {{ section.settings.quote | default: "Parce que chaque femme merite d'etinceler, chaque jour de l'annee." }}
    </blockquote>
    {%- if section.settings.sub != blank -%}
      <p class="editorial-band__sub">{{ section.settings.sub }}</p>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url }}" class="btn btn--ghost-light" style="margin-top:26px;">{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bande editoriale",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image de fond" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Barbara Style" },
    { "type": "textarea", "id": "quote", "label": "Citation", "default": "Parce que chaque femme merite d'etinceler, chaque jour de l'annee." },
    { "type": "text", "id": "sub", "label": "Sous-titre", "default": "Collection Ete" },
    { "type": "text", "id": "cta_label", "label": "Bouton - texte" },
    { "type": "url", "id": "cta_url", "label": "Bouton - lien" }
  ],
  "presets": [{ "name": "Bande editoriale" }]
}
{% endschema %}
