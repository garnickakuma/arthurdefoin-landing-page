<section class="bs-hero">
  <div class="bs-hero__frame">
    <!-- Visuel gauche -->
    <div class="bs-hero__visual">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 1200 }}"
          alt="{{ section.settings.hero_image.alt | default: 'Barbara Style' | escape }}"
          width="1200" height="900"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        <div class="bs-hero__placeholder"></div>
      {%- endif -%}

      <div class="bs-hero__overlay">
        <div class="bs-hero__kicker">{{ section.settings.kicker }}</div>
        <h1 class="bs-hero__title">
          {{ section.settings.title }}<br>
          <em>{{ section.settings.title_accent }}</em>
        </h1>
      </div>
    </div>

    <!-- Panneau carte postale droite -->
    <div class="bs-hero__panel">
      <div class="bs-hero__from">
        {%- render 'postmark', width: 64 -%}
      </div>
      <div class="bs-hero__bonjour">Bonjour,</div>
      <p class="bs-hero__body">{{ section.settings.body }}</p>
      <div class="bs-hero__ctas">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--gold">
          {{ section.settings.cta_label }}
        </a>
        <a href="{{ section.settings.cta2_url | default: '/collections/all' }}" class="btn btn--ghost">
          {{ section.settings.cta2_label }}
        </a>
      </div>
    </div>
  </div>

  <!-- Ticker marquee -->
  <div class="bs-ticker">
    <div class="bs-ticker__inner">
      {% for i in (1..4) %}
        <span>Bijoux plaqués or fin &nbsp;·&nbsp; </span>
        <span><strong>2 achetés = 1 offert</strong> &nbsp;·&nbsp; </span>
        <span>Cache-boutons exclusifs &nbsp;·&nbsp; </span>
        <span>Livraison offerte dès 30&nbsp;€ &nbsp;·&nbsp; </span>
        <span>Retours gratuits &nbsp;·&nbsp; </span>
        <span><strong>4 achetés = 2 offerts</strong> &nbsp;·&nbsp; </span>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Barbara Style",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Photo hero" },
    { "type": "text", "id": "kicker", "label": "Sur-titre", "default": "Nouvelle collection" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Scintiller au" },
    { "type": "text", "id": "title_accent", "label": "Titre italique", "default": "soleil" },
    { "type": "textarea", "id": "body", "label": "Corps du texte", "default": "La collection est arrivee - bijoux dores et cache-boutons lumineux, penses pour vous faire rayonner chaque jour." },
    { "type": "text", "id": "cta_label", "label": "Bouton 1", "default": "Decouvrir la collection" },
    { "type": "url", "id": "cta_url", "label": "Bouton 1 lien" },
    { "type": "text", "id": "cta2_label", "label": "Bouton 2", "default": "Cache-boutons" },
    { "type": "url", "id": "cta2_url", "label": "Bouton 2 lien" }
  ],
  "presets": [{ "name": "Hero Barbara Style" }]
}
{% endschema %}
