<section class="categories-section" aria-label="Catégories">
  <div class="section-header">
    <span class="vx-eyebrow">{{ section.settings.eyebrow | default: 'La boutique' }}</span>
    <h2 class="bs-display">{{ section.settings.title | default: 'Explorez nos univers' }}</h2>
    <div class="gold-line"></div>
  </div>

  <div class="categories-grid">
    {%- for block in section.blocks -%}
      {%- assign cat = block -%}
      <a href="{{ cat.settings.url }}" class="cat-card" {{ block.shopify_attributes }}>
        <div class="cat-card__bg cat-bg--{{ cat.settings.bg_style | default: 'bijoux' }}">
          {%- if cat.settings.image != blank -%}
            <img
              src="{{ cat.settings.image | img_url: '800x800', crop: 'center' }}"
              alt="{{ cat.settings.title | escape }}"
              class="prod-placeholder"
              loading="lazy"
            >
          {%- endif -%}
        </div>
        <div class="cat-card__overlay">
          <h3 class="cat-card__title">{{ cat.settings.title }}</h3>
          <span class="cat-card__sub">{{ cat.settings.subtitle }}</span>
          <span class="cat-card__link">
            {{ cat.settings.cta | default: 'Voir la sélection' }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Categories",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "La boutique" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Explorez nos univers" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categorie",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image de fond" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Bijoux" },
        { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "Boucles - Colliers - Bracelets" },
        { "type": "text", "id": "cta", "label": "Texte du lien", "default": "Voir la selection" },
        { "type": "url", "id": "url", "label": "Lien" },
        { "type": "select", "id": "bg_style", "label": "Couleur de fond (fallback)", "default": "bijoux",
          "options": [
            { "value": "bijoux", "label": "Or chaud" },
            { "value": "cache", "label": "Rose" },
            { "value": "new", "label": "Sable" },
            { "value": "soldes", "label": "Brun" }
          ]
        }
      ]
    }
  ],
  "presets": [{
    "name": "Grille categories",
    "blocks": [
      { "type": "category", "settings": { "title": "Bijoux", "subtitle": "Boucles - Colliers - Bracelets", "bg_style": "bijoux" } },
      { "type": "category", "settings": { "title": "Cache-boutons", "subtitle": "La piece signature", "bg_style": "cache" } },
      { "type": "category", "settings": { "title": "Nouveautes", "subtitle": "Collection ete", "bg_style": "new" } },
      { "type": "category", "settings": { "title": "Soldes", "subtitle": "Jusqu a -40%", "bg_style": "soldes" } }
    ]
  }]
}
{% endschema %}
