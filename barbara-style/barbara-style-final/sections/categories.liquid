<section class="categories-section" aria-label="Categories">
  <div class="categories-section__inner">
    <div class="section-header">
      <span class="vx-eyebrow">{{ section.settings.eyebrow | default: "Explorer" }}</span>
      <h2 class="bs-display">{{ section.settings.title | default: "Par envie" }}</h2>
      <div class="gold-line"></div>
    </div>

    <div class="categories-grid-v2">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.url | default: '/collections/all' }}" class="cat-item" {{ block.shopify_attributes }}>
          <div class="cat-item__media cat-bg--{{ block.settings.bg_style | default: 'bijoux' }} vx-grain">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | img_url: '600x600', crop: 'center' }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            {%- endif -%}
          </div>
          <div class="cat-item__name">{{ block.settings.title }}</div>
          <div class="cat-item__note">{{ block.settings.subtitle }}</div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Categories",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Explorer" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Par envie" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Categorie",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image de fond" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Boucles d'oreilles" },
        { "type": "text", "id": "subtitle", "label": "Note", "default": "Creoles & puces" },
        { "type": "url", "id": "url", "label": "Lien" },
        { "type": "select", "id": "bg_style", "label": "Couleur de fond", "default": "bijoux",
          "options": [
            { "value": "bijoux", "label": "Or chaud" },
            { "value": "colliers", "label": "Rose poudre" },
            { "value": "bracelets", "label": "Ambre" },
            { "value": "cache", "label": "Sable" }
          ]
        }
      ]
    }
  ],
  "presets": [{ "name": "Grille categories" }]
}
{% endschema %}
