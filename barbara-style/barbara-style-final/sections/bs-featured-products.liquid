{%- liquid
  assign col = section.settings.collection
  assign count = section.settings.products_count
-%}

<section class="bs-products">
  <div class="bs-products__header">
    <div class="bs-eyebrow">{{ section.settings.eyebrow }}</div>
    <h2 class="bs-display" style="font-size:clamp(30px,3.5vw,44px);margin:10px 0 0;">{{ section.settings.title }}</h2>
  </div>

  <div class="bs-products__grid">
    {%- if col != blank -%}
      {%- for product in col.products limit: count -%}
        <div class="bs-product-card">
          <a href="{{ product.url }}" class="bs-product-card__img" style="display:block;">
            {%- if product.featured_image -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | default: product.title | escape }}"
                loading="lazy"
                width="600" height="800"
              >
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="bs-product-card__badge">Soldes</span>
            {%- endif -%}
          </a>
          <div class="bs-product-card__body">
            <div class="bs-product-card__type">{{ product.type }}</div>
            <a href="{{ product.url }}" class="bs-product-card__name" style="text-decoration:none;">{{ product.title }}</a>
            <div class="bs-product-card__price">
              {{ product.price | money }}
            </div>
          </div>
          <button
            class="btn btn--gold bs-product-card__add"
            data-bs-add-to-cart="{{ product.first_available_variant.id }}"
            data-product-title="{{ product.title | escape }}"
            {%- unless product.available %} disabled{%- endunless %}
          >
            {%- if product.available %}Ajouter au panier{%- else %}Rupture de stock{%- endif %}
          </button>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..count) -%}
        <div class="bs-product-card">
          <div class="bs-product-card__img" style="background:var(--cream-300);"></div>
          <div class="bs-product-card__body">
            <div class="bs-product-card__type">Bijou</div>
            <div class="bs-product-card__name">Produit exemple {{ i }}</div>
            <div class="bs-product-card__price">29,00 €</div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="bs-products__footer">
    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--ghost btn--lg">
      {{ section.settings.cta_label }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Produits mis en avant",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Nos coups de coeur" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Selection solaire" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_count", "label": "Nombre de produits", "min": 2, "max": 8, "step": 2, "default": 4 },
    { "type": "text", "id": "cta_label", "label": "Bouton texte", "default": "Voir toute la collection" },
    { "type": "url", "id": "cta_url", "label": "Bouton lien" }
  ],
  "presets": [{ "name": "Produits mis en avant" }]
}
{% endschema %}
