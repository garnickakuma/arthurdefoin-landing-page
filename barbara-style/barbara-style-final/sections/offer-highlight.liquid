<section class="offer-highlight" aria-label="Offres">
  <div class="offer-highlight__inner vx-paper">
    <svg viewBox="0 0 200 100" preserveAspectRatio="xMidYMax slice"
      aria-hidden="true"
      style="position:absolute;inset:0;width:100%;height:100%;z-index:0;opacity:.4;pointer-events:none;">
      <line x1="100" y1="100" x2="-100" y2="100" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="-98" y2="73" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="-93" y2="46" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="-84" y2="20" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="-71" y2="-4" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="-55" y2="-26" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="-36" y2="-46" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="-15" y2="-63" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="9" y2="-78" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="33" y2="-88" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="60" y2="-96" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="86" y2="-100" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="114" y2="-100" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="140" y2="-96" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="167" y2="-88" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="191" y2="-78" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="215" y2="-63" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="236" y2="-46" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="255" y2="-26" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="271" y2="-4" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="284" y2="20" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="293" y2="46" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="298" y2="73" stroke="var(--gold-300)" stroke-width="2.2"/>
      <line x1="100" y1="100" x2="300" y2="100" stroke="var(--gold-300)" stroke-width="2.2"/>
    </svg>

    <div class="offer-highlight__grid">
      <div class="offer-highlight__pitch">
        <span class="vx-eyebrow">{{ section.settings.eyebrow | default: "L'OFFRE DE L'ETE" }}</span>
        <h2 class="bs-display offer-title">
          {{ section.settings.title_line1 | default: "Le bijou de plus," }}<br>
          <em class="offer-title__accent">{{ section.settings.title_line2 | default: "c'est nous qui l'offrons" }}</em>
        </h2>
        <p>{{ section.settings.body | default: "Composez votre parure : le moins cher de vos articles vous est offert. Cumulable sur toute la boutique, ajoute automatiquement au panier." }}</p>
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--gold" style="margin-top:8px;">
          {{ section.settings.cta_label | default: "J'EN PROFITE" }}
        </a>
      </div>

      <div class="offer-tickets">
        <div class="offer-ticket">
          <div class="offer-ticket__notch offer-ticket__notch--left"></div>
          <div class="offer-ticket__notch offer-ticket__notch--right"></div>
          <div class="offer-ticket__nums">
            <span class="offer-ticket__buy">2</span>
            <span class="offer-ticket__plus">+</span>
            <span class="offer-ticket__free">1</span>
          </div>
          <div class="offer-ticket__title">Le 3<sup>e</sup> offert</div>
          <p class="offer-ticket__sub">Achetez-en 2, le moins cher est pour vous.</p>
        </div>

        <div class="offer-ticket">
          <div class="offer-ticket__notch offer-ticket__notch--left"></div>
          <div class="offer-ticket__notch offer-ticket__notch--right"></div>
          <div class="offer-ticket__nums">
            <span class="offer-ticket__buy">4</span>
            <span class="offer-ticket__plus">+</span>
            <span class="offer-ticket__free">2</span>
          </div>
          <div class="offer-ticket__title">Deux pieces offertes</div>
          <p class="offer-ticket__sub">Allez plus loin : 2 articles offerts des 6 pieces.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Offres groupees",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "L'OFFRE DE L'ETE" },
    { "type": "text", "id": "title_line1", "label": "Titre ligne 1", "default": "Le bijou de plus," },
    { "type": "text", "id": "title_line2", "label": "Titre ligne 2 (italic or)", "default": "c'est nous qui l'offrons" },
    { "type": "textarea", "id": "body", "label": "Description", "default": "Composez votre parure : le moins cher de vos articles vous est offert. Cumulable sur toute la boutique." },
    { "type": "text", "id": "cta_label", "label": "Bouton texte", "default": "J'EN PROFITE" },
    { "type": "url", "id": "cta_url", "label": "Bouton lien" }
  ],
  "presets": [{ "name": "Offres groupees" }]
}
{% endschema %}
