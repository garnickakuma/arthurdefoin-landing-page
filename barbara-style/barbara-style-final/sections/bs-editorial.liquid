<section class="bs-editorial">
  <div class="bs-editorial__bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1600 }}"
        alt=""
        loading="lazy"
        width="1600" height="900"
      >
    {%- endif -%}
    <div class="bs-editorial__veil"></div>
  </div>
  <div class="bs-editorial__content">
    <div class="bs-eyebrow" style="color:var(--gold-300);">{{ section.settings.eyebrow }}</div>
    <p class="bs-editorial__quote">{{ section.settings.quote }}</p>
    <div class="bs-editorial__sub">{{ section.settings.sub }}</div>
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--gold">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bande editoriale",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image de fond" },
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Barbara Style" },
    { "type": "textarea", "id": "quote", "label": "Citation", "default": "Parce que chaque femme merite d'etinceler, chaque jour de l'annee." },
    { "type": "text", "id": "sub", "label": "Sous-titre", "default": "Collection Ete" },
    { "type": "text", "id": "cta_label", "label": "Bouton texte", "default": "Decouvrir" },
    { "type": "url", "id": "cta_url", "label": "Bouton lien" }
  ],
  "presets": [{ "name": "Bande editoriale" }]
}
{% endschema %}
