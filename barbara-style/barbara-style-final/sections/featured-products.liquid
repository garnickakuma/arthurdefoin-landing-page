<section class="products-section" aria-label="{{ section.settings.title }}">
  <div class="section-header">
    <span class="vx-eyebrow">{{ section.settings.eyebrow | default: 'Nos coups de cœur' }}</span>
    <h2 class="bs-display">{{ section.settings.title | default: 'Sélection solaire' }}</h2>
    <div class="gold-line"></div>
  </div>

  {%- assign collection = section.settings.collection -%}
  {%- assign products_to_show = section.settings.products_count | default: 4 -%}

  {%- if collection != blank -%}
    <div class="products-grid">
      {%- for product in collection.products limit: products_to_show -%}
        {%- render 'vintage-card', product: product -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          <div class="product-card">
            <div class="product-card__media" style="aspect-ratio:4/5;background:var(--cream-300);border-radius:var(--vx-radius-card);"></div>
            <div class="product-card__info">
              <div class="product-card__cat">Bijoux</div>
              <div class="product-card__name">Boucles Riviera</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="products-grid">
      {%- for i in (1..products_to_show) -%}
        <div class="product-card">
          <div class="product-card__media" style="aspect-ratio:4/5;background:var(--cream-300);border-radius:var(--vx-radius-card);"></div>
          <div class="product-card__info">
            <div class="product-card__cat">Bijoux</div>
            <div class="product-card__name">Boucles Riviera</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if section.settings.cta_label != blank -%}
    <div class="section-footer">
      <a href="{{ section.settings.cta_url | default: '/collections/bijoux' }}" class="btn btn--ghost">
        {{ section.settings.cta_label }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Produits mis en avant",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Sur-titre", "default": "Nos coups de coeur" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Selection solaire" },
    { "type": "collection", "id": "collection", "label": "Collection a afficher" },
    { "type": "range", "id": "products_count", "label": "Nombre de produits", "min": 2, "max": 8, "step": 2, "default": 4 },
    { "type": "text", "id": "cta_label", "label": "Bouton - texte", "default": "Voir toute la collection" },
    { "type": "url", "id": "cta_url", "label": "Bouton - lien" }
  ],
  "presets": [{ "name": "Produits mis en avant" }]
}
{% endschema %}
