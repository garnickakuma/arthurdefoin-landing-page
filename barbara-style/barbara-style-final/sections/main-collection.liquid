<div class="collection-header vx-grain vx-veil">
  {%- if collection.image -%}
    <img src="{{ collection.image | img_url: '2000x600', crop: 'center' }}" alt="{{ collection.title | escape }}" class="prod-placeholder" loading="lazy">
  {%- endif -%}
  <div style="position:relative;z-index:2;">
    <span class="vx-eyebrow">{{ collection.metafields.custom.eyebrow | default: 'Collection' }}</span>
    <h1 class="bs-display">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="collection-header__meta">{{ collection.description }}</p>
    {%- endif -%}
    <p class="collection-header__meta" style="color:var(--ink-500);font-size:13px;margin-top:6px;">{{ collection.products_count }} article{{ collection.products_count | pluralize: '', 's' }}</p>
  </div>
</div>

<div class="collection-body">
  <!-- Sidebar filtres -->
  <aside class="collection-sidebar">
    <h2 class="collection-sidebar__title">Filtrer</h2>

    {%- for filter in collection.filters -%}
      <div class="filter-group">
        <div class="filter-group__label">{{ filter.label }}</div>
        <div class="filter-options">
          {%- for value in filter.values -%}
            <label class="bs-checkbox">
              <input
                type="checkbox"
                name="{{ value.param_name }}"
                value="{{ value.value }}"
                {%- if value.active -%}checked{%- endif -%}
                onchange="this.form.submit()"
              >
              {{ value.label }}
              <span style="color:var(--ink-500);font-size:12px;">({{ value.count }})</span>
            </label>
          {%- endfor -%}
        </div>
      </div>
    {%- endfor -%}
  </aside>

  <!-- Grille produits -->
  <div>
    <div class="collection-toolbar">
      <div class="active-filters">
        {%- for filter in collection.filters -%}
          {%- for value in filter.active_values -%}
            <a href="{{ value.url_to_remove }}" class="filter-chip">
              {{ value.label }} ✕
            </a>
          {%- endfor -%}
        {%- endfor -%}
      </div>
      <div class="collection-sort">
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        Trier par&nbsp;:
        <span>
          {%- for option in collection.sort_options -%}
            {%- if option.value == sort_by -%}{{ option.name }}{%- endif -%}
          {%- endfor -%}
        </span>
      </div>
    </div>

    {%- paginate collection.products by 12 -%}
      <div class="collection-grid">
        {%- for product in collection.products -%}
          {%- render 'vintage-card', product: product -%}
        {%- else -%}
          <p style="font-family:var(--font-sans);color:var(--ink-500);grid-column:1/-1;text-align:center;padding:60px 0;">
            Aucun produit dans cette collection.
          </p>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div style="display:flex;justify-content:center;gap:10px;margin-top:52px;align-items:center;">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn--ghost btn--sm">← Précédent</a>
          {%- endif -%}
          <span style="font-family:var(--font-sans);font-size:13px;color:var(--ink-500);">
            Page {{ paginate.current_page }} sur {{ paginate.pages }}
          </span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn--ghost btn--sm">Suivant →</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection principale",
  "settings": [],
  "presets": [{ "name": "Collection principale" }]
}
{% endschema %}
