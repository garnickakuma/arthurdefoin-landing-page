<!DOCTYPE html>
<html lang="fr" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#fefbf6">

  <title>
    {%- if page_title == blank -%}{{ shop.name }}{%- else -%}{{ page_title }} — {{ shop.name }}{%- endif -%}
  </title>
  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | img_url: '32x32' }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500&family=Pinyon+Script&display=swap" rel="stylesheet">

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template | split: '.' | first | replace: '/', '-' }}">

  {%- render 'announcement-bar' -%}

  <header class="site-header" id="site-header" data-sticky>
    <div class="site-header__bar" id="header-bar">
      <div class="site-header__inner">
        <!-- Nav gauche -->
        <nav>
          <ul class="site-nav">
            <li><a href="{{ routes.root_url }}">Accueil</a></li>
            <li><a href="/collections/bijoux">Bijoux</a></li>
            <li><a href="/collections/cache-boutons">Cache-boutons</a></li>
            <li><a href="/collections/nouveautes">Nouveautés</a></li>
          </ul>
        </nav>

        <!-- Logo centré -->
        <a href="{{ routes.root_url }}" class="site-logo" aria-label="{{ shop.name }}">
          <span class="site-logo__name">Barbara</span>
          <span class="site-logo__sub">
            <span>STYLE</span>
          </span>
        </a>

        <!-- Icônes droite -->
        <div class="header-icons">
          <button class="icon-btn" aria-label="Rechercher" id="search-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
          <a href="{{ routes.account_url }}" class="icon-btn" aria-label="Mon compte">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </a>
          <button class="icon-btn" aria-label="Favoris" id="wishlist-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M19 14c1.5-1.5 3-3.2 3-5.5A4.5 4.5 0 0 0 12 5 4.5 4.5 0 0 0 2 8.5C2 10.8 3.5 12.5 5 14l7 7 7-7Z"/></svg>
          </button>
          <button class="icon-btn cart-btn" aria-label="Panier" id="cart-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="cart-badge" id="cart-count" style="display:none">0</span>
          </button>
        </div>
      </div>
    </div>
  </header>

  {%- render 'cart-drawer' -%}

  <main id="main-content">
    {{ content_for_layout }}
  </main>

  {%- render 'footer' -%}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
